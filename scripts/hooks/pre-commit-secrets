#!/usr/bin/env bash
# SPDX-FileCopyrightText: Copyright (c) 2025-2026 NVIDIA CORPORATION & AFFILIATES. All rights reserved.
# SPDX-License-Identifier: Apache-2.0
#
# Pre-commit hook: scans staged files for potential secrets, credentials,
# tokens, and sensitive data. Blocks the commit if anything suspicious is found.
#
# Install: ln -sf ../../scripts/hooks/pre-commit-secrets .git/hooks/pre-commit

set -u

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

VIOLATIONS=0
WARNINGS=0

echo "Scanning staged files for secrets..."
echo ""

# Get all staged file names
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [[ -z "$STAGED_FILES" ]]; then
  echo -e "${GREEN}No staged files to scan.${NC}"
  exit 0
fi

# Get all added lines from the staged diff (combined)
ADDED_LINES=$(git diff --cached -p | grep '^+' | grep -v '^+++' || true)

# --- Pattern scanning function ---
check_pattern() {
  local label="$1"
  local pattern="$2"
  local severity="${3:-error}"

  local found
  found=$(echo "$ADDED_LINES" | grep -iE "$pattern" 2>/dev/null | head -5) || true

  if [[ -n "$found" ]]; then
    if [[ "$severity" == "error" ]]; then
      echo -e "${RED}BLOCKED${NC} [$label]:"
      echo "$found" | sed 's/^+/  /' | head -3
      VIOLATIONS=$((VIOLATIONS + 1))
    else
      echo -e "${YELLOW}WARNING${NC} [$label]:"
      echo "$found" | sed 's/^+/  /' | head -2
      WARNINGS=$((WARNINGS + 1))
    fi
  fi
}

# --- Filename scanning function ---
check_filename() {
  local label="$1"
  local pattern="$2"

  local found
  found=$(echo "$STAGED_FILES" | grep -iE "$pattern" 2>/dev/null) || true

  if [[ -n "$found" ]]; then
    while IFS= read -r f; do
      echo -e "${RED}BLOCKED${NC} [$label] file staged: ${f}"
      VIOLATIONS=$((VIOLATIONS + 1))
    done <<< "$found"
  fi
}

# === HIGH-CONFIDENCE PATTERNS (BLOCK) ===

# AWS keys
check_pattern "AWS Access Key" "AKIA[0-9A-Z]{16}"
check_pattern "AWS Secret Key" "(aws_secret_access_key|aws_secret_key).*[=:].*[A-Za-z0-9/+=]{40}"

# Generic API keys and tokens
check_pattern "API Key assignment" "(api[_-]?key|apikey|api[_-]?token).*[=:].*[A-Za-z0-9_-]{20,}"
check_pattern "Bearer token" "(bearer|authorization).*[=:].*[A-Za-z0-9_.-]{20,}"

# Private keys
check_pattern "Private Key" "-----BEGIN.*PRIVATE KEY-----"
check_pattern "PGP Private Key" "-----BEGIN PGP PRIVATE KEY BLOCK-----"

# GitHub/GitLab tokens
check_pattern "GitHub Token" "(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9_]{36,}"
check_pattern "GitLab Token" "glpat-[A-Za-z0-9-_]{20,}"

# AI provider keys
check_pattern "OpenAI API Key" "sk-[A-Za-z0-9_-]{20,}"
check_pattern "Anthropic API Key" "sk-ant-[A-Za-z0-9_-]{20,}"

# Slack tokens
check_pattern "Slack Token" "xox[baprs]-[A-Za-z0-9-]{10,}"

# Password assignments
check_pattern "Password assignment" "(password|passwd|pwd).*[=:].*['\"][^'\"]{8,}"

# Database connection strings with embedded credentials
check_pattern "DB URI with credentials" "(postgres|mysql|mongodb|redis)://[^:]+:[^@]+@"

# JWT tokens (actual tokens, not code references)
check_pattern "JWT Token" "eyJ[A-Za-z0-9_-]{10,}\.eyJ[A-Za-z0-9_-]{10,}\."

# Vault tokens
check_pattern "Vault Token" "(vault_token|VAULT_TOKEN).*[=:].*s\.[A-Za-z0-9]{20,}"
check_pattern "Vault Token (hvs)" "hvs\.[A-Za-z0-9_-]{20,}"

# === FILENAME BLOCKS ===

check_filename "Environment file" "\.(env|env\.local|env\.production|env\.staging)$"
check_filename "Credentials file" "(credentials|creds)\.(json|yaml|yml|toml)$"
check_filename "Private key file" "\.(pem|key|p12|pfx|jks)$"
check_filename "Kubeconfig" "(kubeconfig|\.kube/config)"
check_filename "SSH private key" "id_(rsa|dsa|ecdsa|ed25519)$"
check_filename "Terraform state" "terraform\.tfstate"

# === WARNINGS (flag but don't block) ===

check_pattern "TODO secret" "(todo|fixme|hack).*secret" "warning"

# === SUMMARY ===

echo ""
if [[ $VIOLATIONS -gt 0 ]]; then
  echo -e "${RED}COMMIT BLOCKED: $VIOLATIONS secret(s) detected in staged files.${NC}"
  echo ""
  echo "To fix:"
  echo "  1. Remove the secret from your code"
  echo "  2. Use environment variables or a secrets manager (Vault, ESO)"
  echo "  3. Add the file to .gitignore if it should never be committed"
  echo ""
  echo "If this is a false positive, bypass with: git commit --no-verify"
  exit 1
elif [[ $WARNINGS -gt 0 ]]; then
  echo -e "${YELLOW}$WARNINGS warning(s) found (not blocking).${NC}"
  exit 0
else
  echo -e "${GREEN}No secrets detected. Commit allowed.${NC}"
  exit 0
fi
