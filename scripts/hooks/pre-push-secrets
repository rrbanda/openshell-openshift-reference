#!/usr/bin/env bash
# Pre-push hook: scans ALL commits being pushed for secrets.
# This is the last line of defense before code reaches the remote.
#
# Install: ln -sf ../../scripts/hooks/pre-push-secrets .git/hooks/pre-push

set -u

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

VIOLATIONS=0

# Read the push info from stdin (provided by git)
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch — scan all commits
    range="$local_sha"
  else
    # Existing branch — scan only new commits
    range="$remote_sha..$local_sha"
  fi

  # Get all added content in the push range
  DIFF=$(git log "$range" -p --diff-filter=ACM 2>/dev/null | grep '^+' | grep -v '^+++' || true)

  if [ -z "$DIFF" ]; then
    continue
  fi

  # Critical patterns that must NEVER reach the remote
  PATTERNS=(
    "AKIA[0-9A-Z]{16}"
    "(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9_]{36,}"
    "glpat-[A-Za-z0-9_-]{20,}"
    "-----BEGIN.*PRIVATE KEY-----"
    "eyJ[A-Za-z0-9_-]{10,}\.eyJ[A-Za-z0-9_-]{10,}\."
    "xox[baprs]-[A-Za-z0-9-]{10,}"
    "hvs\.[A-Za-z0-9_-]{20,}"
    "(postgres|mysql|mongodb|redis)://[^:]+:[^@]+@"
    "sk-ant-[A-Za-z0-9_-]{20,}"
  )

  for pattern in "${PATTERNS[@]}"; do
    matches=$(echo "$DIFF" | grep -E "$pattern" 2>/dev/null | head -3) || true
    if [ -n "$matches" ]; then
      echo -e "${RED}PUSH BLOCKED: Secret detected matching [$pattern]${NC}"
      echo "$matches" | sed 's/^+/  /' | head -3
      VIOLATIONS=$((VIOLATIONS + 1))
    fi
  done
done

if [ "$VIOLATIONS" -gt 0 ]; then
  echo ""
  echo -e "${RED}PUSH BLOCKED: $VIOLATIONS secret pattern(s) found in commits being pushed.${NC}"
  echo "Remove the secrets, amend the commits, then push again."
  echo "Bypass (DANGEROUS): git push --no-verify"
  exit 1
fi

echo -e "${GREEN}Pre-push secret scan passed.${NC}"
exit 0
